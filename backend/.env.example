# ========================================
# NEOBUSINESS AI - CONFIGURAÇÃO DE AMBIENTE
# ========================================
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commit o arquivo .env no git!

# ==================== DATABASE ====================
# PostgreSQL connection string (OBRIGATÓRIO)
# Formato: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/neobusiness_ai

# ==================== AI / LLM ====================
# Groq API Key (OBRIGATÓRIO)
# Obtenha em: https://console.groq.com/keys
AI_SOVEREIGN_ENABLED=true
AI_ROUTING_POLICY=local_only
LOCAL_AI_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_AI_SECONDARY_URL=
LOCAL_AI_API_KEY=ollama
LOCAL_AI_FAST_MODEL=qwen2.5-coder:1.5b
LOCAL_AI_QUICK_MODEL=lex-juridica-instant:1.5b
LOCAL_AI_BALANCED_MODEL=lex-juridica-rapida:3b
LOCAL_AI_DEEP_MODEL=lex-juridica:14b
LOCAL_AI_EMBEDDING_MODEL=nomic-embed-text
LOCAL_AI_TIMEOUT_SECONDS=1200
LOCAL_AI_MAX_RETRIES=0
LOCAL_AI_KEEP_ALIVE=15m
LOCAL_AI_CONTEXT_TOKENS=8192
AI_KNOWLEDGE_TOP_K=6
AI_KNOWLEDGE_MIN_SCORE=0.18
AI_LAZY_EMBED_BATCH=8
AI_REALTIME_OFFICIAL_SEARCH_ENABLED=true
AI_REALTIME_OFFICIAL_SEARCH_MAX_RESULTS=5
AI_REALTIME_OFFICIAL_SEARCH_CACHE_SECONDS=600
AI_EXTERNAL_FALLBACK_ENABLED=false

# Groq e opcional e fica desligada na operacao local.
GROQ_API_KEY=

# OpenAI API Key (OPCIONAL - backup)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic API Key (OPCIONAL - backup)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ==================== FIREBASE ====================
# Firebase Project ID (OBRIGATÓRIO)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Private Key (OBRIGATÓRIO)
# Copie a chave completa do console Firebase (incluindo -----BEGIN PRIVATE KEY-----)
# Use aspas duplas e \n para quebras de linha
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Client Email (OBRIGATÓRIO)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com

# ==================== STRIPE (Pagamentos) ====================
# Stripe Secret Key (OPCIONAL)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Publishable Key (OPCIONAL)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Webhook Secret (OPCIONAL)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==================== SMTP (Email) ====================
# SMTP Server (OPCIONAL - para notificações)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ==================== REDIS (Cache) ====================
# Redis connection string (OPCIONAL - recomendado para produção)
REDIS_URL=redis://localhost:6379/0

# ==================== APLICAÇÃO ====================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (false em produção)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== SEGURANÇA ====================
# Secret key para JWT (OBRIGATÓRIO - mínimo 32 caracteres)
# Gere um com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_super_secret_key_minimum_32_characters_long

# Access token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== LIMITES ====================
# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# Max documents per user (free tier)
MAX_DOCUMENTS_PER_USER=100

# ==================== CORS ====================
# CORS origins (comma-separated, use * para todos)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==================== TWILIO (WhatsApp) ====================
# Twilio Account SID (OPCIONAL)
TWILIO_ACCOUNT_SID=your_twilio_account_sid

# Twilio Auth Token (OPCIONAL)
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio WhatsApp Number (OPCIONAL)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
